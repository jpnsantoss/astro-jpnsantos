---
import { getExperience } from "../../utils/sanity";
import { PortableText } from 'astro-portabletext';

const experiences = await getExperience();

const components = {
  list: {
    bullet: ({ children }: any) => <ul class="list-disc ml-4">{children}</ul>,
    number: ({ children }: any) => <ol class="list-decimal ml-4">{children}</ol>,
  },
  listItem: {
    bullet: ({ children }: any) => <li>{children}</li>,
    number: ({ children }: any) => <li>{children}</li>,
  },
};
---

<section class="space-y-8 pb-16">
  <h2 class="text-4xl font-bold text-primary">Experience</h2>
  <div class="space-y-6">
    {
      experiences.map((experience) => (
        <div class="bg-muted rounded-card p-6 flex flex-col md:flex-row items-start space-y-4 md:space-y-0 md:space-x-4">
          <img
            src={experience.company.logo}
            alt={experience.company.name}
            class="w-20 h-20 rounded-full object-cover"
          />
          <div class="flex-1">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between">
              <div>
                <h3 class="text-2xl text-primary font-semibold">
                  {experience.title}
                </h3>
                <div class="flex gap-2 items-center">
                  <p class="text-lg text-foreground">
                    {experience.company.name}
                  </p>
                  <span>·</span>
                  <p class="text-sm text-muted-foreground">
                    {experience.location}
                  </p>
                </div>
                <p class="text-sm text-muted-foreground">
                  {experience.startDate} - {experience.endDate}
                </p>
              </div>
            </div>
            <div class="mt-4 text-gray-700">
              <PortableText value={experience.description} components={components} />
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
